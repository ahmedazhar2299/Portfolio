---
import LinkInline from "./LinkInline.astro"

interface Props {
  title: string
  company: string
  description: string
  highlights?: string[]
  link?: string
  date: string
}

const { title, company, description, highlights = [], link, date } = Astro.props
---

<article class="surface-card rounded-2xl p-5 md:p-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h3 class="text-xl font-semibold text-slate-900 dark:text-slate-100">{title}</h3>
      <p class="text-sm text-slate-600 dark:text-slate-300">{company}</p>
    </div>

    <time class="eyebrow">{date}</time>
  </div>

  <p class="mt-3 text-[0.98rem] leading-relaxed">{description}</p>

  {
    highlights.length > 0 && (
      <ul class="mt-3 grid gap-2 text-sm text-slate-700 dark:text-slate-300">
        {highlights.map((item) => <li class="leading-relaxed">• {item}</li>)}
      </ul>
    )
  }

  {
    link && (
      <div class="mt-4">
        <LinkInline href={link}>
          Visit company
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M9 6l6 6l-6 6" />
          </svg>
        </LinkInline>
      </div>
    )
  }
</article>
