---
import SunIcon from "./icons/Sun.astro"
import MoonIcon from "./icons/Moon.astro"
import SystemIcon from "./icons/System.astro"

const THEMES = ["light", "dark", "system"]
---

<div class="relative ml-1 mr-1">
  <button
    transition:persist
    id="theme-toggle-btn"
    type="button"
    class="theme-trigger"
    aria-expanded="false"
    aria-controls="themes-menu"
    aria-label="Choose color theme"
  >
    <SunIcon id="light" class="theme-toggle-icon size-4 transition-all" />
    <MoonIcon id="dark" class="theme-toggle-icon absolute size-4 transition-all" />
    <SystemIcon id="system" class="theme-toggle-icon absolute size-4 transition-all" />
  </button>

  <div
    transition:persist
    id="themes-menu"
    class="theme-menu absolute hidden top-9 right-0 min-w-[8rem] rounded-xl p-1"
  >
    <ul class="space-y-0.5">
      {
        THEMES.map((theme) => (
          <li>
            <button type="button" class="themes-menu-option block w-full rounded-lg px-2.5 py-1.5 text-left capitalize" data-theme={theme}>
              {theme}
            </button>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<style>
  .theme-trigger {
    align-items: center;
    border-radius: 999px;
    border: 1px solid var(--surface-border);
    color: var(--text-main);
    display: inline-flex;
    height: 1.95rem;
    justify-content: center;
    position: relative;
    transition: all 180ms ease;
    width: 1.95rem;
  }

  .theme-trigger:hover {
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    transform: translateY(-1px);
  }

  .theme-menu {
    border: 1px solid var(--surface-border);
    background: color-mix(in srgb, var(--surface) 92%, transparent);
    backdrop-filter: blur(16px);
    box-shadow: 0 14px 36px rgba(2, 6, 23, 0.15);
  }

  .themes-menu-option {
    color: var(--text-main);
    font-size: 0.8rem;
    transition: background-color 160ms ease;
  }

  .themes-menu-option:hover,
  .themes-menu-option:focus-visible {
    background: color-mix(in srgb, var(--surface) 92%, transparent);
  }

  .theme-menu.open {
    display: inline;
    animation: scale-up-center 0.15s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }

  @keyframes scale-up-center {
    from {
      transform: scale(0.86);
      opacity: 0;
    }

    to {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>

<script is:inline>
  let remove = null
  const matchMedia = window.matchMedia("(prefers-color-scheme: dark)")
  const themesMenu = document.getElementById("themes-menu")
  const toggleButton = document.getElementById("theme-toggle-btn")

  const getThemePreference = () => {
    if (typeof localStorage !== "undefined") {
      return localStorage.getItem("theme") ?? "system"
    }

    return matchMedia.matches ? "dark" : "light"
  }

  const updateIcon = (themePreference) => {
    document.querySelectorAll(".theme-toggle-icon").forEach((element) => {
      element.style.scale = element.id === themePreference ? "1" : "0"
    })
  }

  const updateTheme = () => {
    if (remove != null) remove()

    matchMedia.addEventListener("change", updateTheme)
    remove = () => {
      matchMedia.removeEventListener("change", updateTheme)
    }

    const themePreference = getThemePreference()
    const isDark =
      themePreference === "dark" ||
      (themePreference === "system" && matchMedia.matches)

    updateIcon(themePreference)
    document.documentElement.classList.toggle("dark", isDark)
  }

  const closeMenu = () => {
    themesMenu.classList.remove("open")
    toggleButton.setAttribute("aria-expanded", "false")
  }

  const toggleMenu = () => {
    const shouldOpen = !themesMenu.classList.contains("open")
    themesMenu.classList.toggle("open", shouldOpen)
    toggleButton.setAttribute("aria-expanded", String(shouldOpen))
  }

  updateTheme()

  document.addEventListener("click", closeMenu)

  toggleButton.addEventListener("click", (e) => {
    e.stopPropagation()
    toggleMenu()
  })

  document.querySelectorAll(".themes-menu-option").forEach((element) => {
    element.addEventListener("click", (e) => {
      const chosenTheme = e.currentTarget.getAttribute("data-theme")
      localStorage.setItem("theme", chosenTheme)
      updateTheme()
      closeMenu()
    })
  })

  document.addEventListener("astro:after-swap", () => {
    updateTheme()
    closeMenu()
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  })
</script>
