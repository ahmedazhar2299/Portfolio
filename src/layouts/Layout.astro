---
import "@fontsource-variable/onest"
import "@fontsource-variable/space-grotesk"

import { ViewTransitions } from "astro:transitions"
import Header from "@/components/Header.astro"
import Footer from "@/components/Footer.astro"
import FloatingOrbs from "@/components/react/FloatingOrbs"

interface Props {
  title: string
  description: string
  image?: string
}

const { description, title, image = "/porfolio.webp" } = Astro.props

const canonicalUrl = new URL(Astro.url.pathname, Astro.site)
const imageUrl = new URL(image, Astro.site)

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Muhammad Ahmed",
  url: canonicalUrl.href,
  image: imageUrl.href,
  jobTitle: "Software Engineer",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Los Angeles",
    addressRegion: "CA",
    addressCountry: "US",
  },
  sameAs: [
    "https://github.com/ahmedazhar2299",
    "https://www.linkedin.com/in/ahmedazhar2299/",
  ],
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Muhammad Ahmed, software engineer, portfolio, AI engineer, cloud engineer, backend engineer" />
    <meta name="author" content="Muhammad Ahmed" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="theme-color" content="#f3f4f6" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#09090b" media="(prefers-color-scheme: dark)" />

    <link rel="canonical" href={canonicalUrl.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={imageUrl.href} />
    <meta property="og:site_name" content="Muhammad Ahmed Portfolio" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl.href} />

    <script is:inline>
      const storedTheme = localStorage.getItem("theme") ?? "system"
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches
      const isDark = storedTheme === "dark" || (storedTheme === "system" && prefersDark)
      document.documentElement.classList.toggle("dark", isDark)
    </script>

    <script is:inline type="application/ld+json" set:html={JSON.stringify(personJsonLd)}></script>
    <ViewTransitions />
  </head>

  <body class="relative text-zinc-900 dark:text-zinc-100">
    <a class="skip-link" href="#main-content">Skip to content</a>

    <div class="page-background" aria-hidden="true">
      <div class="grid-overlay"></div>
      <div class="vignette"></div>
      <div class="noise"></div>
    </div>

    <div class="bg-wordmark" aria-hidden="true">AHMED</div>

    <FloatingOrbs client:load />

    <Header />
    <slot />
    <Footer />

    <style is:global>
      :root {
        color-scheme: light dark;
        --bg-main: #f5f7fa;
        --bg-soft: #eceff3;
        --surface: rgba(255, 255, 255, 0.56);
        --surface-strong: rgba(255, 255, 255, 0.78);
        --surface-border: rgba(24, 24, 27, 0.09);
        --text-main: #111827;
        --text-muted: #4b5563;
        --brand: #111827;
        --brand-strong: #09090b;
      }

      .dark {
        --bg-main: #09090b;
        --bg-soft: #0f0f12;
        --surface: rgba(24, 24, 27, 0.48);
        --surface-strong: rgba(24, 24, 27, 0.65);
        --surface-border: rgba(250, 250, 250, 0.12);
        --text-main: #fafafa;
        --text-muted: #a1a1aa;
        --brand: #fafafa;
        --brand-strong: #e4e4e7;
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family: "Onest Variable", system-ui, sans-serif;
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg-main);
        color: var(--text-main);
        overscroll-behavior: none;
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: "Space Grotesk Variable", "Onest Variable", system-ui, sans-serif;
        letter-spacing: -0.03em;
      }

      p {
        color: var(--text-muted);
      }

      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: 100;
        border-radius: 0.75rem;
        background: #111827;
        color: #fafafa;
        padding: 0.6rem 0.85rem;
      }

      .skip-link:focus {
        left: 1rem;
        top: 1rem;
      }

      .page-background {
        position: fixed;
        inset: 0;
        z-index: -4;
        background:
          radial-gradient(circle at 12% 14%, rgba(255, 255, 255, 0.85), transparent 48%),
          radial-gradient(circle at 90% 0%, rgba(255, 255, 255, 0.7), transparent 32%),
          linear-gradient(180deg, var(--bg-main), var(--bg-soft));
      }

      .dark .page-background {
        background:
          radial-gradient(circle at 12% 14%, rgba(255, 255, 255, 0.05), transparent 48%),
          radial-gradient(circle at 90% 0%, rgba(255, 255, 255, 0.04), transparent 32%),
          linear-gradient(180deg, var(--bg-main), var(--bg-soft));
      }

      .grid-overlay {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(to right, color-mix(in srgb, var(--surface-border) 48%, transparent) 1px, transparent 1px),
          linear-gradient(to bottom, color-mix(in srgb, var(--surface-border) 48%, transparent) 1px, transparent 1px);
        background-size: 46px 46px;
        mask-image: radial-gradient(circle at center, black 18%, transparent 82%);
        opacity: 0.65;
      }

      .vignette {
        position: absolute;
        inset: 0;
        box-shadow: inset 0 0 220px rgba(2, 6, 23, 0.08);
      }

      .dark .vignette {
        box-shadow: inset 0 0 260px rgba(0, 0, 0, 0.48);
      }

      .noise {
        position: absolute;
        inset: 0;
        background-image: radial-gradient(circle at 1px 1px, rgba(0, 0, 0, 0.06) 1px, transparent 0);
        background-size: 4px 4px;
        opacity: 0.08;
      }

      .dark .noise {
        opacity: 0.06;
      }

      .bg-wordmark {
        pointer-events: none;
        position: fixed;
        bottom: -4.4rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: -3;
        font-size: clamp(5rem, 19vw, 18rem);
        font-weight: 760;
        line-height: 0.9;
        letter-spacing: -0.06em;
        color: transparent;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0));
        background-clip: text;
        opacity: 0.55;
        user-select: none;
      }

      .dark .bg-wordmark {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.11), rgba(255, 255, 255, 0));
      }

      .floating-orbs {
        position: fixed;
        inset: 0;
        z-index: -2;
        pointer-events: none;
      }

      .floating-orbs .orb {
        position: absolute;
        border-radius: 9999px;
        filter: blur(64px);
        opacity: 0.26;
      }

      .floating-orbs .orb-one {
        width: 280px;
        height: 280px;
        left: 2%;
        top: 20%;
        background: rgba(255, 255, 255, 0.9);
      }

      .floating-orbs .orb-two {
        width: 240px;
        height: 240px;
        right: 2%;
        top: 34%;
        background: rgba(212, 212, 216, 0.84);
      }

      .floating-orbs .orb-three {
        width: 220px;
        height: 220px;
        left: 39%;
        bottom: 4%;
        background: rgba(228, 228, 231, 0.74);
      }

      .dark .floating-orbs .orb-one {
        background: rgba(255, 255, 255, 0.14);
      }

      .dark .floating-orbs .orb-two {
        background: rgba(255, 255, 255, 0.08);
      }

      .dark .floating-orbs .orb-three {
        background: rgba(255, 255, 255, 0.12);
      }

      .surface-card {
        border: 1px solid var(--surface-border);
        background: linear-gradient(160deg, var(--surface-strong), var(--surface));
        backdrop-filter: blur(20px);
        border-radius: 1.2rem;
        box-shadow:
          0 18px 45px rgba(15, 23, 42, 0.08),
          0 1px 0 rgba(255, 255, 255, 0.55) inset;
      }

      .dark .surface-card {
        box-shadow:
          0 16px 40px rgba(0, 0, 0, 0.35),
          0 1px 0 rgba(255, 255, 255, 0.05) inset;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border: 1px solid var(--surface-border);
        border-radius: 9999px;
        font-size: 0.72rem;
        font-weight: 520;
        line-height: 1;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 0.46rem 0.76rem;
        color: var(--text-muted);
        background: color-mix(in srgb, var(--surface-strong) 72%, transparent);
      }

      .section-title {
        font-size: clamp(1.4rem, 1.8vw, 1.85rem);
        line-height: 1.1;
      }

      ::selection {
        background: rgba(17, 24, 39, 0.15);
      }

      .dark ::selection {
        background: rgba(255, 255, 255, 0.16);
      }

      @media (max-width: 640px) {
        .bg-wordmark {
          bottom: -1.2rem;
          font-size: clamp(3.6rem, 26vw, 7rem);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }
    </style>
  </body>
</html>
