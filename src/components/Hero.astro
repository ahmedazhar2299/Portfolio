---
import Badge from "@/components/Badge.astro"
import SocialPill from "@/components/SocialPill.astro"
import LinkedInIcon from "@/components/icons/LinkedIn.astro"
import GithubIcon from "@/components/icons/GitHub.astro"
import ResumeIcon from "@/components/icons/Resume.astro"
import MailIcon from "@/components/icons/Mail.astro"

const personalImageAlt = "Portrait of Muhammad Ahmed"

const stats = [
  { label: "Public Repos", value: "27" },
  { label: "Followers", value: "6" },
  { label: "Experience", value: "2+ years" },
]
---

<section class="hero-grid grid gap-10 md:grid-cols-[1.2fr_0.8fr] md:items-center">
  <div>
    <span class="eyebrow">Los Angeles, California · Open to impactful roles</span>

    <h1 class="mt-4 text-4xl font-bold leading-tight sm:text-5xl lg:text-6xl">
      Building AI-native products and cloud systems that scale with confidence.
    </h1>

    <p class="mt-5 max-w-2xl text-lg leading-relaxed">
      I’m <strong>Muhammad Ahmed</strong>, a software engineer focused on backend-heavy systems,
      machine-learning workflows, and reliable product delivery. I turn research-grade ideas into
      production-grade experiences.
    </p>

    <div class="mt-6">
      <Badge>Available for software engineering and AI platform opportunities</Badge>
    </div>

    <nav class="mt-8 flex flex-wrap gap-3" aria-label="Primary links">
      <SocialPill href="mailto:ahmed.azhar2299@gmail.com">
        <MailIcon class="size-4" />
        Email
      </SocialPill>
      <SocialPill href="https://github.com/ahmedazhar2299">
        <GithubIcon class="size-4" />
        GitHub
      </SocialPill>
      <SocialPill href="https://www.linkedin.com/in/ahmedazhar2299/">
        <LinkedInIcon class="size-4" />
        LinkedIn
      </SocialPill>
      <SocialPill href="/resume/resume.pdf">
        <ResumeIcon class="size-4" />
        Resume
      </SocialPill>
    </nav>

    <div class="mt-8 grid gap-3 sm:grid-cols-3">
      {
        stats.map((item) => (
          <article class="surface-card rounded-2xl p-3.5">
            <p class="text-xs uppercase tracking-[0.14em] text-slate-500 dark:text-slate-400">{item.label}</p>
            <p class="mt-1 text-xl font-semibold text-slate-900 dark:text-slate-100">{item.value}</p>
          </article>
        ))
      }
    </div>
  </div>

  <aside class="surface-card relative overflow-hidden rounded-3xl p-4 sm:p-5">
    <div class="absolute -top-12 -right-12 h-36 w-36 rounded-full bg-cyan-400/30 blur-3xl"></div>
    <div class="absolute -bottom-14 -left-10 h-44 w-44 rounded-full bg-emerald-400/20 blur-3xl"></div>

    <div class="relative">
      <img
        class="aspect-square w-full rounded-2xl object-cover object-top"
        src="/ahmed.webp"
        alt={personalImageAlt}
        loading="eager"
        width="640"
        height="640"
      />

      <div class="mt-4 rounded-xl border border-slate-200/60 bg-white/70 p-3 dark:border-slate-700/70 dark:bg-slate-900/60">
        <p class="text-xs uppercase tracking-[0.14em] text-slate-500 dark:text-slate-400">GitHub Snapshot</p>
        <p class="mt-1 text-sm text-slate-700 dark:text-slate-300">
          27 public repositories spanning AI, vision, distributed learning, and systems-level optimization.
        </p>
        <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">Synced from GitHub profile · March 31, 2026</p>
      </div>
    </div>
  </aside>
</section>
