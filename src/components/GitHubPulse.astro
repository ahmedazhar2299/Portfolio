---
import GitHub from "./icons/GitHub.astro"
import LinkButton from "./LinkButton.astro"

const highlights = [
  {
    name: "Sobel-Laplacian-OpenMP",
    language: "C",
    summary: "Parallel edge detection implementation focused on OpenMP throughput gains.",
    href: "https://github.com/ahmedazhar2299/Sobel-Laplacian-OpenMP",
  },
  {
    name: "Pix2CT",
    language: "Jupyter Notebook",
    summary: "CT reconstruction + classification pipeline using Pix2Pix and MobileNetV2.",
    href: "https://github.com/ahmedazhar2299/Pix2CT",
  },
  {
    name: "AI-Chess",
    language: "Python",
    summary: "Alpha-beta pruned chess engine for fast and accurate move selection.",
    href: "https://github.com/ahmedazhar2299/AI-Chess",
  },
  {
    name: "federated-learning-cifar10-analysis",
    language: "Jupyter Notebook",
    summary: "Compares IID vs non-IID federated learning behavior and convergence.",
    href: "https://github.com/ahmedazhar2299/federated-learning-cifar10-analysis",
  },
]

const languageMix = [
  ["JavaScript", 8],
  ["Jupyter Notebook", 3],
  ["C", 2],
  ["Python", 2],
  ["Java", 2],
  ["C++", 1],
  ["TypeScript", 1],
]
---

<div class="surface-card rounded-2xl p-5 md:p-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <p class="eyebrow">Live GitHub extraction</p>
      <h3 class="mt-2 text-2xl font-semibold text-slate-900 dark:text-slate-100">Open-source and research momentum</h3>
      <p class="mt-2 text-sm">Profile snapshot: 27 public repositories · 6 followers · 11 following.</p>
    </div>

    <LinkButton href="https://github.com/ahmedazhar2299">
      <GitHub class="size-4" />
      View profile
    </LinkButton>
  </div>

  <div class="mt-5 grid gap-3 md:grid-cols-2">
    {
      highlights.map((repo) => (
        <article class="rounded-xl border border-slate-200/70 bg-white/65 p-4 dark:border-slate-700/70 dark:bg-slate-900/45">
          <div class="flex items-center justify-between gap-2">
            <h4 class="text-base font-semibold text-slate-900 dark:text-slate-100">{repo.name}</h4>
            <span class="text-xs text-slate-500 dark:text-slate-400">{repo.language}</span>
          </div>
          <p class="mt-2 text-sm leading-relaxed">{repo.summary}</p>
          <a class="mt-3 inline-block text-sm font-medium text-cyan-700 transition hover:text-cyan-500 dark:text-cyan-300" href={repo.href} target="_blank" rel="noopener noreferrer">
            Open repository →
          </a>
        </article>
      ))
    }
  </div>

  <div class="mt-5 rounded-xl border border-slate-200/70 bg-white/65 p-4 dark:border-slate-700/70 dark:bg-slate-900/45">
    <p class="text-xs uppercase tracking-[0.14em] text-slate-500 dark:text-slate-400">Language mix (non-fork repos)</p>
    <div class="mt-2 flex flex-wrap gap-2">
      {
        languageMix.map(([name, count]) => (
          <span class="rounded-full border border-slate-200/70 px-2.5 py-1 text-xs text-slate-700 dark:border-slate-700/70 dark:text-slate-300">
            {name} · {count}
          </span>
        ))
      }
    </div>
    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">Source: GitHub API sync on March 31, 2026.</p>
  </div>
</div>
