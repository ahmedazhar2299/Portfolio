---
const { href, target = href?.startsWith("mailto:") ? undefined : "_blank" } = Astro.props
const rel = target === "_blank" ? "noopener noreferrer" : undefined
---

<a
  href={href}
  target={target}
  rel={rel}
  role="link"
  class="social-pill"
>
  <slot />
</a>

<style>
  .social-pill {
    align-items: center;
    background: color-mix(in srgb, var(--surface-strong) 86%, transparent);
    border: 1px solid var(--surface-border);
    border-radius: 999px;
    color: var(--text-main);
    display: inline-flex;
    font-size: 0.9rem;
    font-weight: 530;
    gap: 0.5rem;
    justify-content: center;
    max-width: fit-content;
    padding: 0.58rem 0.95rem;
    transition:
      transform 170ms ease,
      background-color 170ms ease,
      border-color 170ms ease,
      box-shadow 170ms ease;
  }

  .social-pill:hover {
    border-color: color-mix(in srgb, var(--text-main) 25%, var(--surface-border));
    background: color-mix(in srgb, var(--surface-strong) 96%, transparent);
    box-shadow: 0 14px 30px rgba(2, 6, 23, 0.11);
    transform: translateY(-1px);
  }

  .social-pill:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--text-main) 35%, white 65%);
    outline-offset: 2px;
  }
</style>
