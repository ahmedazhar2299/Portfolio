---
import Layout from "@/layouts/Layout.astro"

import AboutMe from "@/components/AboutMe.astro"
import Briefcase from "@/components/icons/Briefcase.astro"
import CodeIcon from "@/components/icons/Code.astro"
import Experience from "@/components/Experience.astro"
import GitHubIcon from "@/components/icons/GitHub.astro"
import ProfileCheck from "@/components/icons/ProfileCheck.astro"
import Projects from "@/components/Projects.astro"
import Hero from "@/components/Hero.astro"
import GitHubPulse from "@/components/GitHubPulse.astro"
import MotionSection from "@/components/react/MotionSection"
---

<Layout
  title="Muhammad Ahmed | Software Engineer - AI & Cloud Systems"
  description="Software engineer in Los Angeles building AI-powered products, cloud-scale platforms, and performance-focused systems. Explore experience, projects, and GitHub work."
>
  <main id="main-content" class="mx-auto w-full max-w-5xl px-4 pb-4 pt-28 md:pt-36">
    <MotionSection client:visible className="pb-12 md:pb-16" delay={0.04}>
      <Hero />
    </MotionSection>

    <div class="space-y-16 md:space-y-20">
      <section id="experience" class="scroll-m-28">
        <MotionSection client:visible delay={0.08} className="space-y-6">
          <h2 class="section-title flex items-center gap-x-3">
            <Briefcase class="size-6" />
            Experience
          </h2>
          <Experience />
        </MotionSection>
      </section>

      <section id="github-pulse" class="scroll-m-28">
        <MotionSection client:visible delay={0.1} className="space-y-6">
          <h2 class="section-title flex items-center gap-x-3">
            <GitHubIcon class="size-6" />
            GitHub Pulse
          </h2>
          <GitHubPulse />
        </MotionSection>
      </section>

      <section id="projects" class="scroll-m-28">
        <MotionSection client:visible delay={0.12} className="space-y-6">
          <h2 class="section-title flex items-center gap-x-3">
            <CodeIcon class="size-6" />
            Featured Projects
          </h2>
          <Projects />
        </MotionSection>
      </section>

      <section id="about-me" class="scroll-m-28 pb-2">
        <MotionSection client:visible delay={0.14} className="space-y-6">
          <h2 class="section-title flex items-center gap-x-3">
            <ProfileCheck class="size-6" />
            About
          </h2>
          <AboutMe />
        </MotionSection>
      </section>
    </div>
  </main>
</Layout>
