---
const { href, target = "_blank" } = Astro.props
---

<a
  href={href}
  target={target}
  rel="noopener noreferrer"
  role="link"
  class="link-button"
>
  <slot />
</a>

<style>
  .link-button {
    align-items: center;
    background: color-mix(in srgb, var(--surface-strong) 88%, transparent);
    border: 1px solid var(--surface-border);
    border-radius: 0.9rem;
    color: var(--text-main);
    display: inline-flex;
    font-size: 0.86rem;
    font-weight: 520;
    gap: 0.45rem;
    justify-content: center;
    padding: 0.5rem 0.76rem;
    transition:
      transform 170ms ease,
      border-color 170ms ease,
      background-color 170ms ease,
      box-shadow 170ms ease;
  }

  .link-button:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--text-main) 24%, var(--surface-border));
    background: color-mix(in srgb, var(--surface-strong) 96%, transparent);
    box-shadow: 0 12px 24px rgba(2, 6, 23, 0.1);
  }

  .link-button:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--text-main) 35%, white 65%);
    outline-offset: 2px;
  }
</style>
