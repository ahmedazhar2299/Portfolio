---
import GitHub from "./icons/GitHub.astro"
import LinkIcon from "./icons/Link.astro"
import LinkButton from "./LinkButton.astro"

const PROJECTS = [
  {
    title: "RoboInk: Automated 3D Card Printing System",
    description:
      "Automated personalized print jobs for e-commerce by converting SVG designs to G-code and orchestrating fulfillment through a Django + AWS pipeline.",
    stack: ["Python", "Django", "AWS", "MySQL"],
    category: "Production",
    image: "/projects/Roboink.webp",
    imageAlt: "RoboInk platform preview",
    github: "https://github.com/ahmedazhar2299/",
    demo: "https://roboink.de/",
  },
  {
    title: "Artsy: Real-Time Art Auction Platform",
    description:
      "Built a low-latency bidding experience with live updates, secure checkout flow, and concurrent auction handling for digital art marketplaces.",
    stack: ["React", "Node.js", "WebSockets", "MongoDB"],
    category: "Production",
    image: "/projects/Artsy.webp",
    imageAlt: "Artsy digital auction interface",
    github: "https://github.com/MusaMalikx/Artsy",
    demo: "https://artsy-delta.vercel.app/signin",
  },
  {
    title: "Pix2CT",
    description:
      "Deep learning work combining Pix2Pix GAN CT reconstruction with MobileNetV2 transfer learning for brain CT classification under limited medical data settings.",
    stack: ["GAN", "Computer Vision", "Jupyter"],
    category: "Research",
    github: "https://github.com/ahmedazhar2299/Pix2CT",
  },
  {
    title: "AI-Chess",
    description:
      "Python chess engine with alpha-beta pruning for efficient move search and adaptive strategies across multiple skill levels.",
    stack: ["Python", "Game AI", "Search"],
    category: "Systems AI",
    github: "https://github.com/ahmedazhar2299/AI-Chess",
  },
  {
    title: "Sobel-Laplacian-SIMD",
    description:
      "SIMD-accelerated edge detection on Apple Silicon using ARM NEON intrinsics for higher pixel throughput and better cache efficiency.",
    stack: ["C", "SIMD", "Performance"],
    category: "High Performance",
    github: "https://github.com/ahmedazhar2299/Sobel-Laplacian-SIMD",
  },
]
---

<div class="grid gap-5 md:grid-cols-2">
  {
    PROJECTS.map(({ title, description, stack, category, image, imageAlt, github, demo }) => (
      <article class="surface-card group overflow-hidden rounded-2xl">
        <div class="relative h-44 overflow-hidden border-b border-zinc-900/10 dark:border-zinc-100/10">
          {
            image ? (
              <img
                src={image}
                alt={imageAlt}
                class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                width="1200"
                height="720"
              />
            ) : (
              <div class="flex h-full items-center justify-center bg-gradient-to-br from-zinc-200/65 to-zinc-100/65 text-lg font-semibold text-zinc-800 dark:from-zinc-800/55 dark:to-zinc-900/55 dark:text-zinc-100">
                {title}
              </div>
            )
          }

          <span class="absolute left-3 top-3 rounded-full border border-zinc-900/10 bg-white/85 px-2.5 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.12em] text-zinc-700 dark:border-zinc-100/10 dark:bg-zinc-900/80 dark:text-zinc-200">
            {category}
          </span>
        </div>

        <div class="p-4 md:p-5">
          <h3 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">{title}</h3>

          <p class="mt-2 text-[0.95rem] leading-relaxed">{description}</p>

          <ul class="mt-3 flex flex-wrap gap-1.5">
            {stack.map((tag) => <li class="rounded-full border border-zinc-900/12 px-2.5 py-1 text-xs text-zinc-700 dark:border-zinc-100/12 dark:text-zinc-300">{tag}</li>)}
          </ul>

          <footer class="mt-4 flex flex-wrap gap-2.5">
            <LinkButton href={github}>
              <GitHub class="size-4" />
              Code
            </LinkButton>

            {
              demo && (
                <LinkButton href={demo}>
                  <LinkIcon class="size-4" />
                  Live
                </LinkButton>
              )
            }
          </footer>
        </div>
      </article>
    ))
  }
</div>
