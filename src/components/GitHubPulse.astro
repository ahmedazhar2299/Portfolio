---
import GitHub from "./icons/GitHub.astro"
import LinkButton from "./LinkButton.astro"

const highlights = [
  {
    name: "Campaign-Funding-Dapp",
    language: "JavaScript",
    summary: "Decentralized campaign funding application using Truffle, React, Redux Toolkit, and Solidity.",
    href: "https://github.com/ahmedazhar2299/Campaign-Funding-Dapp",
  },
  {
    name: "Sobel-Laplacian-OpenMP",
    language: "C",
    summary: "Parallel image edge detection implementation optimized for OpenMP throughput.",
    href: "https://github.com/ahmedazhar2299/Sobel-Laplacian-OpenMP",
  },
  {
    name: "Pix2CT",
    language: "Jupyter Notebook",
    summary: "CT reconstruction and classification pipeline combining Pix2Pix and MobileNetV2.",
    href: "https://github.com/ahmedazhar2299/Pix2CT",
  },
  {
    name: "AI-Chess",
    language: "Python",
    summary: "Alpha-beta pruned chess engine focused on fast and adaptive move selection.",
    href: "https://github.com/ahmedazhar2299/AI-Chess",
  },
]

const languageMix = [
  ["JavaScript", 8],
  ["Jupyter Notebook", 3],
  ["C", 2],
  ["Python", 2],
  ["Java", 2],
  ["Astro", 1],
]
---

<div class="surface-card rounded-2xl p-5 md:p-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <p class="eyebrow">Live GitHub extraction</p>
      <h3 class="mt-2 text-2xl font-semibold text-zinc-900 dark:text-zinc-100">Open-source and research momentum</h3>
      <p class="mt-2 text-sm">Profile snapshot: 27 public repositories · 6 followers · 11 following.</p>
    </div>

    <LinkButton href="https://github.com/ahmedazhar2299">
      <GitHub class="size-4" />
      View profile
    </LinkButton>
  </div>

  <div class="mt-5 grid gap-3 md:grid-cols-2">
    {
      highlights.map((repo) => (
        <article class="rounded-xl border border-zinc-900/10 bg-white/65 p-4 dark:border-zinc-100/10 dark:bg-zinc-900/45">
          <div class="flex items-center justify-between gap-2">
            <h4 class="text-base font-semibold text-zinc-900 dark:text-zinc-100">{repo.name}</h4>
            <span class="text-xs text-zinc-500 dark:text-zinc-400">{repo.language}</span>
          </div>
          <p class="mt-2 text-sm leading-relaxed">{repo.summary}</p>
          <a class="mt-3 inline-block text-sm font-medium text-zinc-900 transition hover:text-zinc-700 dark:text-zinc-100 dark:hover:text-zinc-300" href={repo.href} target="_blank" rel="noopener noreferrer">
            Open repository →
          </a>
        </article>
      ))
    }
  </div>

  <div class="mt-5 rounded-xl border border-zinc-900/10 bg-white/65 p-4 dark:border-zinc-100/10 dark:bg-zinc-900/45">
    <p class="text-xs uppercase tracking-[0.14em] text-zinc-500 dark:text-zinc-400">Language mix (non-fork repos)</p>
    <div class="mt-2 flex flex-wrap gap-2">
      {
        languageMix.map(([name, count]) => (
          <span class="rounded-full border border-zinc-900/12 px-2.5 py-1 text-xs text-zinc-700 dark:border-zinc-100/12 dark:text-zinc-300">
            {name} · {count}
          </span>
        ))
      }
    </div>
    <p class="mt-2 text-xs text-zinc-500 dark:text-zinc-400">Source: GitHub API sync on April 1, 2026.</p>
  </div>
</div>
