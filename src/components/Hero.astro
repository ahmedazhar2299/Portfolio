---
import Badge from "@/components/Badge.astro"
import SocialPill from "@/components/SocialPill.astro"
import LinkedInIcon from "@/components/icons/LinkedIn.astro"
import GithubIcon from "@/components/icons/GitHub.astro"
import ResumeIcon from "@/components/icons/Resume.astro"
import MailIcon from "@/components/icons/Mail.astro"

const personalImageAlt = "Portrait of Muhammad Ahmed"

const stats = [
  { label: "Public Repos", value: "27" },
  { label: "Followers", value: "6" },
  { label: "Experience", value: "2+ years" },
]
---

<section class="hero-grid grid gap-5 lg:grid-cols-[1.2fr_0.8fr] lg:items-stretch">
  <div class="surface-card rounded-[1.6rem] p-6 sm:p-8">
    <span class="eyebrow">Los Angeles, California</span>

    <h1 class="mt-5 text-4xl font-semibold leading-[1.03] sm:text-5xl lg:text-[3.35rem]">
      Futuristic software experiences powered by robust AI and cloud engineering.
    </h1>

    <p class="mt-5 max-w-2xl text-base leading-relaxed sm:text-[1.03rem]">
      I’m <strong>Muhammad Ahmed</strong>, a software engineer focused on resilient backend systems,
      AI workflows, and product execution that balances speed with reliability.
    </p>

    <div class="mt-6">
      <Badge>Open to software engineering and applied AI opportunities</Badge>
    </div>

    <nav class="mt-8 flex flex-wrap gap-2.5" aria-label="Primary links">
      <SocialPill href="mailto:ahmed.azhar2299@gmail.com">
        <MailIcon class="size-4" />
        Email
      </SocialPill>
      <SocialPill href="https://github.com/ahmedazhar2299">
        <GithubIcon class="size-4" />
        GitHub
      </SocialPill>
      <SocialPill href="https://www.linkedin.com/in/ahmedazhar2299/">
        <LinkedInIcon class="size-4" />
        LinkedIn
      </SocialPill>
      <SocialPill href="/resume/resume.pdf">
        <ResumeIcon class="size-4" />
        Resume
      </SocialPill>
    </nav>

    <div class="mt-8 grid gap-2.5 sm:grid-cols-3">
      {
        stats.map((item) => (
          <article class="rounded-2xl border border-zinc-900/10 bg-white/55 px-3.5 py-3 dark:border-zinc-100/10 dark:bg-zinc-900/45">
            <p class="text-[0.67rem] uppercase tracking-[0.15em] text-zinc-500 dark:text-zinc-400">{item.label}</p>
            <p class="mt-1 text-lg font-semibold text-zinc-900 dark:text-zinc-100">{item.value}</p>
          </article>
        ))
      }
    </div>
  </div>

  <aside class="surface-card relative overflow-hidden rounded-[1.6rem] p-4 sm:p-5">
    <div class="absolute -top-16 -right-14 h-44 w-44 rounded-full bg-white/70 blur-3xl dark:bg-white/15"></div>
    <div class="absolute -bottom-16 -left-10 h-44 w-44 rounded-full bg-zinc-200/70 blur-3xl dark:bg-zinc-200/10"></div>

    <div class="relative">
      <img
        class="aspect-[4/4.35] w-full rounded-2xl object-cover object-top"
        src="/ahmed.webp"
        alt={personalImageAlt}
        loading="eager"
        width="640"
        height="640"
      />

      <div class="mt-4 rounded-xl border border-zinc-900/10 bg-white/70 p-3.5 dark:border-zinc-100/10 dark:bg-zinc-900/55">
        <p class="text-[0.67rem] uppercase tracking-[0.15em] text-zinc-500 dark:text-zinc-400">GitHub Pulse</p>
        <p class="mt-1.5 text-sm leading-relaxed text-zinc-700 dark:text-zinc-300">
          27 public repositories across AI, performance systems, and full-stack shipping projects.
        </p>
        <p class="mt-1.5 text-xs text-zinc-500 dark:text-zinc-400">Synced from GitHub API on April 1, 2026.</p>
      </div>
    </div>
  </aside>
</section>
