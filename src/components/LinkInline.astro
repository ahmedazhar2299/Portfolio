---
const { href } = Astro.props
---

<a href={href} role="link" class="inline-link">
  <slot />
</a>

<style>
  .inline-link {
    align-items: center;
    color: var(--brand-strong);
    display: inline-flex;
    font-weight: 560;
    gap: 0.3rem;
    transition: color 160ms ease;
  }

  .inline-link:hover {
    color: var(--text-main);
  }
</style>
